classDiagram
    class Task {
        +str description
        +str time
        +str frequency
        +bool completed
        +mark_complete() None
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) None
        +list_tasks() list
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +get_all_tasks() list[Pet, Task]
    }

    class Scheduler {
        +Owner owner
        +sort_by_time() list[Pet, Task]
        +detect_conflicts() list[str]
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : reads